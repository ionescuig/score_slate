# Optional — used when the app has a public URL (canonical link, Open Graph URL, default share image).
# Copy to `.env` for local experiments; set real values in your host’s environment for production.
#
# NUXT_PUBLIC_SITE_URL=https://your-domain.example
# NUXT_PUBLIC_OG_IMAGE_URL=https://your-domain.example/og.png
#
# Optional — self-hosted Umami (page views + events). Omit locally unless you want hits in dev.
# NUXT_PUBLIC_UMAMI_SCRIPT_URL=https://your-umami-host.example/script.js
# NUXT_PUBLIC_UMAMI_WEBSITE_ID=00000000-0000-4000-8000-000000000000
